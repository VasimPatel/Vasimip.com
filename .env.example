# Postgres connection string (dev: docker run -d --name dash-pg -e POSTGRES_PASSWORD=dev \
#   -e POSTGRES_DB=dash -p 5433:5432 postgres:16 → postgres://postgres:dev@localhost:5433/dash)
DATABASE_URL=postgres://postgres:dev@localhost:5433/dash

# Bun server port (default 8787).
PORT=8787

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
# Signing secret for sessions/tokens — generate with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=change-me-32+-random-chars

# The ONLY email allowed to create an account / sign in.
OWNER_EMAIL=you@example.com

# Public origin the auth handler runs on (default http://localhost:8787).
BASE_URL=http://localhost:8787

# Resend API key for magic-link email. If unset, dev logs the link to the server
# console instead of sending mail.
RESEND_API_KEY=
# Optional verified sender for Resend (default: onboarding@resend.dev).
RESEND_FROM=
